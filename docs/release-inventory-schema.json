{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/randlee/agent-team-mail/blob/main/docs/release-inventory-schema.json",
  "title": "ATM Release Inventory",
  "description": "Machine-readable release inventory required by requirements.md section 4.8.6.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "releaseVersion",
    "releaseTag",
    "releaseCommit",
    "generatedAt",
    "items"
  ],
  "properties": {
    "releaseVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "releaseTag": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "releaseCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approver",
        "reason",
        "gateCheck"
      ],
      "properties": {
        "approver": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "gateCheck": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "evidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "waived"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact",
        "version",
        "sourceRef",
        "publishTarget",
        "verifyCommands"
      ],
      "properties": {
        "artifact": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        },
        "publishTarget": {
          "type": "string",
          "enum": [
            "crates.io",
            "github-release",
            "homebrew"
          ]
        },
        "verifyCommands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "waiver": {
          "$ref": "#/$defs/waiver"
        }
      }
    }
  }
}
