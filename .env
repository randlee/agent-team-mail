# Claude Code environment for agent-team-mail development
# Task list ID links to the project task tracker; agent teams enables experimental multi-agent features
CLAUDE_CODE_TASK_LIST_ID=agent-team-mail
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
ATM_TEAM=atm-dev

# Dev environment (dogfood channel)
ATM_DEV_ROOT=/Users/randlee/.local/atm-dev
PATH=/Users/randlee/.local/atm-dev/bin:$PATH
ATM_DAEMON_BIN=/Users/randlee/.local/atm-dev/bin/atm-daemon
ATM_CHANNEL=dev
